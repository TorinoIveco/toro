# ============================================================
# TORO Insights — variáveis de ambiente (copie para .env)
# ============================================================

# Conexão PostgreSQL / Supabase (driver psycopg 3)
# Formato: postgresql+psycopg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+psycopg://postgres:SUA_SENHA@db.SEUPROJ.supabase.co:5432/postgres

# Schema da aplicação
DB_SCHEMA=toro

# Salt para pseudonimização do documento (RN-11). NÃO versione o valor real.
DOCUMENTO_HASH_SALT=troque-este-salt

# Janela (em dias) para casar Valor Faturado da NF à oportunidade (RN-13)
NF_MATCH_JANELA_DIAS=30

# Diretório onde linhas inválidas são gravadas (quarentena)
QUARENTENA_DIR=./data/quarentena

# Loguru
LOG_LEVEL=INFO
LOG_FILE=./logs/toro_insights.log

# Acesso ao app Streamlit (persona: Gerente de Marketing)
APP_USUARIO=gerente
APP_SENHA=troque-esta-senha

# Assistente IA — Google Gemini
GEMINI_API_KEY=sua-chave-gemini
GEMINI_MODEL=gemini-2.5-flash
