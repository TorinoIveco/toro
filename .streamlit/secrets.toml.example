# ============================================================
# TORO Insights — Secrets para Streamlit Cloud
# Copie o conteúdo abaixo para:
#   Streamlit Cloud → Settings → Secrets
# NÃO versione o arquivo secrets.toml real.
# ============================================================

DATABASE_URL       = "postgresql+psycopg://postgres.SEUREF:SUASENHA@aws-1-us-west-2.pooler.supabase.com:5432/postgres"
DB_SCHEMA          = "toro"
DOCUMENTO_HASH_SALT = "troque-por-valor-aleatorio-longo"

APP_USUARIO = "gerente"
APP_SENHA   = "troque-por-senha-forte"

# Perfil ASSISTENTE (sem acesso à tela "Atualizar Dados"). Opcional.
APP_ASSISTENTE_USUARIO = "assistente"
APP_ASSISTENTE_SENHA   = "troque-por-senha-forte"

GEMINI_API_KEY = "sua-chave-gemini"
GEMINI_MODEL   = "gemini-2.5-flash"

LOG_LEVEL      = "INFO"
LOG_FILE       = "/tmp/toro_insights.log"
QUARENTENA_DIR = "/tmp/quarentena"
